# Profiler results
Builds/**/Intel*VTune*Profiler*Results/

# Build outputs and artifacts
Builds/*/x64/
Builds/*/x86/
Builds/*/Debug/
Builds/*/Release/
Builds/*/RelWithDebInfo/
Builds/*/MinSizeRel/
Builds/*/build/
Builds/*/release/

# Plugin installer outputs (.pkg, .exe, .tar.gz)
Plugin/Installer/Output/
Plugin/Builds/

# Compiled binaries
*.exe
*.dll
*.so
*.dylib
*.app

# Exception: the prebuilt AMD/HIP GPU plugin is committed on purpose because the
# Windows CI runner has no AMD HIP SDK to build it (see
# tools/windows/prebuilt/README.md). Force-tracked despite the *.dll rule above.
!tools/windows/prebuilt/wfs_hip.dll

# Object files
*.obj
*.o
*.lo
*.slo

# Debug symbols
*.pdb
*.ilk
*.map

# Build logs and temporary files
*.log
*.tlog
*.recipe
*.lastbuildstate
*.FileListAbsolute.txt
*.Build.CppClean.log

# Visual Studio temporary files
*.vcxproj.user
*.suo
*.user
*.userosscache
*.sln.docstates

# Visual Studio cache and temporary directories
.vs/
.vscode/

# Visual Studio build outputs (already covered by general patterns above)
Builds/*/x64/
Builds/*/x86/
Builds/*/Debug/
Builds/*/Release/

# Xcode temporary files
*.pbxuser
*.mode1v3
*.mode2v3
*.perspectivev3
*.xcuserstate
project.xcworkspace/
xcuserdata/

# CMake build files
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile

# IDE files
.vscode/
.idea/
.claude/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# JUCE specific — JuceLibraryCode/ is tracked so users can build without Projucer

# Build configuration files (generated by JUCE/Projucer)
# These ARE tracked so users can clone and build without Projucer.
# After saving in Projucer, review changes with `git diff` before committing.

# Processor build artifacts
Processors/*/build/
Processors/*/out/
# Claude Code temporary files
tmpclaude-*
**/tmpclaude-*

# Python cache and test artefacts (Phase 0 generator script)
__pycache__/
.pytest_cache/
Experiments/metal-wfs-spike/spike
Experiments/metal-wfs-spike/backend_test
