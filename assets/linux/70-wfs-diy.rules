# udev rules granting non-root access to HID controllers used by WFS-DIY.
#
# Install with:
#   sudo cp assets/linux/50-wfs-diy.rules /etc/udev/rules.d/
#   sudo udevadm control --reload-rules
#   sudo udevadm trigger
# (Or unplug and replug the device after reloading the rules.)
#
# TAG+="uaccess" grants the active console user dynamic ACL access on
# systemd-logind systems. GROUP="plugdev" is the older fallback — add the
# user to the plugdev group on distros without uaccess.

# Elgato Stream Deck Plus (VID 0fd9, PID 0084)
SUBSYSTEM=="usb",     ATTRS{idVendor}=="0fd9", ATTRS{idProduct}=="0084", MODE="0660", TAG+="uaccess", GROUP="plugdev"
KERNEL=="hidraw*",    ATTRS{idVendor}=="0fd9", ATTRS{idProduct}=="0084", MODE="0660", TAG+="uaccess", GROUP="plugdev"

# 3Dconnexion SpaceMouse — current-generation devices share VID 256f.
# PID is left unmatched so all SpaceMouse models are covered.
SUBSYSTEM=="usb",     ATTRS{idVendor}=="256f", MODE="0660", TAG+="uaccess", GROUP="plugdev"
KERNEL=="hidraw*",    ATTRS{idVendor}=="256f", MODE="0660", TAG+="uaccess", GROUP="plugdev"

# Touchscreen evdev access — legacy. Since JUCE 9 the app reads touch
# natively via XInput2 (no direct evdev access), so WFS-DIY itself no longer
# needs this rule; it is kept for older releases whose evdev backend read
# /dev/input/eventN directly, and is harmless otherwise.
KERNEL=="event*", ENV{ID_INPUT_TOUCHSCREEN}=="1", MODE="0660", TAG+="uaccess", GROUP="plugdev"
